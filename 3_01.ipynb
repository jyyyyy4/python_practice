   "source": [
    "def get_average(*args):\n",
    "    if len(args) == 0:\n",
    "        return 0\n",
    "\n",
    "    return sum(args) / len(args)\n",
    "\n",
    "print(get_average(10, 20, 30))\n",
    "print(get_average(1, 2, 3, 4, 5, 6))"
   ]
  }
